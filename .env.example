# Cloudflare Pages Environment Variables
# Paste these into: Cloudflare Dashboard → Pages → Your Site → Settings → Environment Variables

# === RESEND (Email) ===
# Get from: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for emails to Manny
# Use onboarding@resend.dev for testing, or your verified domain
RESEND_FROM_EMAIL=onboarding@resend.dev

# Manny's email — where lead notifications go
MANNY_NOTIFY_EMAIL=manny@example.com

# === AIRTABLE (Lead Dashboard) ===
# Get from: airtable.com/create/tokens → Create token → scopes: data.records:write
AIRTABLE_API_KEY=patXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Open your base, look at URL: airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Name of your table (default: Leads)
AIRTABLE_TABLE_NAME=Leads

# === OPTIONAL: ConvertKit (Newsletter) ===
# Get from: convertkit.com → Account → API Key
CONVERTKIT_API_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONVERTKIT_FORM_ID=1234567

# === OPTIONAL: Twilio (SMS alerts for high-priority leads) ===
# Get from: twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890
MANNY_PHONE_NUMBER=+1234567890