# Cloudflare Pages Environment Variables
# Paste these into: Cloudflare Dashboard → Pages → Your Site → Settings → Environment Variables

# === RESEND (Email) ===
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
MANNY_NOTIFY_EMAIL=manny@example.com

# === AIRTABLE (Lead Dashboard) ===
AIRTABLE_API_KEY=your_airtable_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_NAME=Leads

# === OPTIONAL: ConvertKit (Newsletter) ===
# CONVERTKIT_API_KEY=your_convertkit_key_here
# CONVERTKIT_FORM_ID=your_form_id_here

# === OPTIONAL: Twilio (SMS alerts for high-priority leads) ===
# TWILIO_ACCOUNT_SID=your_twilio_sid_here
# TWILIO_AUTH_TOKEN=your_twilio_token_here
# TWILIO_FROM_PHONE=+1234567890
# TWILIO_TO_PHONE=+1234567890
